# =============================================
# AI検図システム 環境変数設定例
# このファイルを .env にコピーして値を設定してください
# .env は .gitignore に含まれており Git には追加されません
# =============================================

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- Azure Form Recognizer (OCR精度不足時のフォールバック、任意) ---
# AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_FORM_RECOGNIZER_KEY=your_azure_key_here

# --- アプリ設定 ---
DEBUG=false

# --- ストレージパス (Dockerボリュームを使う場合はそのまま) ---
UPLOAD_DIR=/data/uploads
OUTPUT_DIR=/data/outputs
DATABASE_URL=sqlite+aiosqlite:////data/drawing_checker.db
